  "theme": {
    "$description": "Modos do DS. Apenas semantic muda entre modos; primitivos são fixos por natureza. Modo CB é combinável com dark (html.cb-mode[data-theme='dark']).",

    "light": {
      "$description": "Tema padrão. Fundos claros, texto escuro, cores saturadas.",
      "active": true
    },

    "dark": {
      "$description": "Tema escuro — ativado via [data-theme='dark']. Fundos profundos (neutral-950+), texto claro, cores levemente mais saturadas para compensar contraste.",
